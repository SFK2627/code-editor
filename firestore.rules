rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // No public sign-up is provided in the app.
    // Any user manually added in Firebase Authentication can manage rubric/activity data.
    function isTeacher() {
      return request.auth != null;
    }

    match /webCodeEditor/{classDoc} {
      // Students can read activities/rubrics.
      allow read: if true;

      // Only signed-in Firebase teacher accounts can create/edit/delete activities/rubrics.
      allow create, update, delete: if isTeacher();

      match /submissions/{submissionId} {
        // Students can submit results.
        allow create: if true;

        // Only signed-in teacher can view/manage submitted results.
        allow read, update, delete: if isTeacher();
      }
    }
  }
}
