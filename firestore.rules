rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isTeacher() {
      // The app has no sign-up form, so only users manually added in Firebase
      // Authentication can sign in and edit activities/rubrics.
      return request.auth != null;
    }

    match /webCodeEditor/{classDoc} {
      // Students can read activities/rubrics.
      allow read: if true;

      // Only signed-in Firebase teacher account can create/edit/delete activities/rubrics.
      allow create, update, delete: if isTeacher();

      match /submissions/{submissionId} {
        // Students can submit results.
        allow create: if true;

        // Only signed-in teacher can view/manage submitted results.
        allow read, update, delete: if isTeacher();
      }
    }
  }
}
